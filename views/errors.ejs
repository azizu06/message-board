<% if (errors?.length) { %>
  <div class="px-5 pt-6 sm:px-8">
    <section
      class="overflow-hidden rounded-[1.5rem] border border-rose-200 bg-[radial-gradient(circle_at_top_left,_rgba(244,63,94,0.12),_transparent_34%),linear-gradient(135deg,_#fffdfd,_#fff1f2_58%,_#ffe4e6)]"
      aria-labelledby="form-errors-title"
    >
      <div class="border-b border-rose-200/70 px-4 py-4 sm:px-5">
        <p
          id="form-errors-title"
          class="text-sm font-semibold uppercase tracking-[0.2em] text-rose-600"
        >
          Submission Error
        </p>
        <p class="mt-2 text-sm leading-6 text-slate-600">
          Fix the following issues before sending your message.
        </p>
      </div>

      <ul class="space-y-3 px-4 py-4 text-sm text-slate-700 sm:px-5">
        <% errors.forEach((err) => { %>
          <li
            class="flex items-start gap-3 rounded-2xl border border-white/70 bg-white/80 px-4 py-3 shadow-sm shadow-rose-100/70"
          >
            <span
              class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-rose-500 text-xs font-semibold text-white"
            >
              !
            </span>
            <span><%= err.msg %></span>
          </li>
        <% }); %>
      </ul>
    </section>
  </div>
<% } %>
