<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles.css" />
    <title>Message Board</title>
  </head>
  <body class="min-h-screen bg-slate-100 text-slate-900">
    <main class="mx-auto flex min-h-screen w-full max-w-5xl flex-col gap-8 px-4 py-8 sm:px-6 lg:px-8">
      <section class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_20px_60px_-24px_rgba(15,23,42,0.28)]">
        <div class="border-b border-slate-200 bg-[radial-gradient(circle_at_top_left,_rgba(16,185,129,0.14),_transparent_38%),linear-gradient(135deg,_#ffffff,_#f8fafc_60%,_#eef2ff)] px-5 py-8 sm:px-8">
          <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
            <div class="max-w-2xl">
              <p class="text-sm font-medium uppercase tracking-[0.28em] text-emerald-600">
                Community Feed
              </p>
              <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">
                Message Board
              </h1>
              <p class="mt-3 max-w-xl text-sm leading-6 text-slate-600 sm:text-base">
                A clean shared space for quick updates, conversations, and new posts.
              </p>
            </div>

            <div class="flex flex-col gap-3 sm:items-end">
              <div class="inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-emerald-50 px-4 py-2 text-sm font-medium text-emerald-900">
                <i data-lucide="users" class="h-4 w-4"></i>
                <span><%= messages.length %> messages</span>
              </div>

              <a
                href="/new"
                class="inline-flex items-center justify-center gap-2 rounded-full bg-slate-950 px-5 py-3 text-sm font-medium text-white transition hover:-translate-y-0.5 hover:bg-slate-800"
              >
                <i data-lucide="plus" class="h-4 w-4"></i>
                Add Message
              </a>
            </div>
          </div>
        </div>

        <div class="bg-slate-50/70 px-5 py-6 sm:px-8 sm:py-8">
          <div class="grid gap-4">
            <% messages.forEach((msg) => { %>
              <%- include("msgCard", { msg }); %>
            <% }); %>
          </div>
        </div>
      </section>
    </main>
    <%- include("lucide") %>
  </body>
</html>
